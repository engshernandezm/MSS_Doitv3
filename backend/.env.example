# ──────────────────────────────────────────
# Base de datos PostgreSQL
# ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=doitv3
DB_USER=postgres
DB_PASSWORD=Admin1234

# ──────────────────────────────────────────
# JWT
# ──────────────────────────────────────────
JWT_SECRET=cambia_esto_por_cadena_larga_y_secreta_minimo_32_chars
JWT_EXPIRES_IN=8h

# ──────────────────────────────────────────
# Servidor
# ──────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5500

# ──────────────────────────────────────────
# Email (Gmail con contraseña de aplicación)
# Dejar vacío → el enlace se imprime en consola
# ──────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=FonzControl <noreply@fonz.mx>

# ──────────────────────────────────────────
# WhatsApp Business API (Meta Cloud API)
# Dejar vacío → mensajes se imprimen en consola
# ──────────────────────────────────────────
WA_PHONE_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=fonzcontrol_webhook_verify_2024

# ──────────────────────────────────────────
# OCR (Google Cloud Vision)
# Dejar vacío → se usa OCR mock con datos de prueba
# ──────────────────────────────────────────
GOOGLE_VISION_API_KEY=

# ──────────────────────────────────────────
# URL pública del backend (para links en emails y WhatsApp)
# ──────────────────────────────────────────
APP_URL=http://localhost:5500
API_URL=http://localhost:3000

# ──────────────────────────────────────────
# Almacenamiento de archivos
# ──────────────────────────────────────────
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=10
